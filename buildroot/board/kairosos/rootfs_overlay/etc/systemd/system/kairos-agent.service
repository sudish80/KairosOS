[Unit]
Description=KairosOS AI Agent (Hermes)
Documentation=https://kairosos.org/docs
Wants=network-online.target
After=network-online.target local-fs.target systemd-user-sessions.service

[Service]
Type=simple
User=kairos
Group=kairos
WorkingDirectory=/home/kairos
Environment=HOME=/home/kairos
Environment=HERMES_CONFIG=/etc/kairos/hermes.yaml
Environment=HERMES_DATA_DIR=/home/kairos/.hermes
Environment=PATH=/opt/hermes/bin:/usr/local/bin:/usr/bin:/bin
ExecStartPre=/usr/bin/kairos-agent-check
ExecStart=/opt/hermes/bin/hermes --config /etc/kairos/hermes.yaml
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5
RestartMaxDelaySec=30
RestartSteps=3

# Security hardening
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/kairos/.hermes /tmp /var/log/kairos
PrivateTmp=true
NoNewPrivileges=true
CapabilityBoundingSet=CAP_NET_BIND_SERVICE CAP_DAC_OVERRIDE CAP_SYS_PTRACE
MemoryMax=2G
TasksMax=256

[Install]
WantedBy=multi-user.target
