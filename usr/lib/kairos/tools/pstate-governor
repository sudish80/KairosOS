#!/bin/bash
# 011: Coherent Interconnect Bandwidth Scaling / CPUFreq governor manager
set -euo pipefail

GOV="${1:-schedutil}"

echo "$GOV" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor 2>/dev/null || {
    for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
        echo "$GOV" > "$cpu" 2>/dev/null || true
    done
}
echo "CPUFreq governor set to $GOV"
echo "Available governors: $(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_available_governors 2>/dev/null)"
