#!/bin/bash
# 052: RAM-Evaporating Panic Switch
# Links sysrq to physical sensors — overwrites encryption keys with null on theft.
set -euo pipefail

ACTION="${1:-status}"

KEY_PATTERNS='sk-[a-zA-Z0-9]{20,}|-----BEGIN.*PRIVATE KEY-----|AI[a-zA-Z0-9_-]{30,}'

case "$ACTION" in
    arm)
        echo 1 > /proc/sys/kernel/sysrq 2>/dev/null || true
        echo "Panic switch armed. SysRq enabled."
        echo "Trigger: echo x > /proc/sysrq-trigger"
        ;;
    shred_keys)
        echo "Overwriting encryption keys in memory..."
        # Scrub common key patterns from /proc/*/maps and /proc/*/mem would need root+ptrace
        # Instead, clear kernel keyrings
        keyctl clear 0xFFFFFFFF 2>/dev/null || true  # @s keyring
        keyctl clear 0xFFFFFFFE 2>/dev/null || true  # @u keyring
        keyctl clear 0xFFFFFFFD 2>/dev/null || true  # @us keyring
        echo 1 > /proc/sys/vm/drop_caches 2>/dev/null || true
        echo "Key material shred requested"
        ;;
    status)
        echo "SysRq: $(cat /proc/sys/kernel/sysrq 2>/dev/null)"
        echo "Keyrings:"
        keyctl show 2>/dev/null || echo "  No keyctl"
        ;;
esac
