#!/bin/bash
# 208: Real-Time DNS Leak Eliminator
# Binds resolution to loopback, strips leaks from VPN/mesh configs.
set -euo pipefail

ACTION="${1:-status}"

case "$ACTION" in
    enable)
        # Route all DNS through local stub
        mkdir -p /etc/systemd/resolved.conf.d
        cat > /etc/systemd/resolved.conf.d/kairos-dns.conf << 'EOF'
[Resolve]
DNS=127.0.0.1
DNSStubListener=yes
DNSSEC=allow-downgrade
DNSOverTLS=opportunistic
EOF
        systemctl restart systemd-resolved 2>/dev/null || true
        echo "DNS leak protection enabled (127.0.0.1 stub)"
        ;;
    disable)
        rm -f /etc/systemd/resolved.conf.d/kairos-dns.conf
        systemctl restart systemd-resolved 2>/dev/null || true
        echo "DNS leak protection disabled"
        ;;
    check)
        echo "=== DNS Leak Check ==="
        echo "Resolvers:"
        resolvectl status 2>/dev/null | grep -E 'DNS Server|Current DNS' || cat /etc/resolv.conf
        echo "VPN DNS configs:"
        resolvectl dns tun0 2>/dev/null || echo "  No tun0"
        resolvectl dns wg0 2>/dev/null || echo "  No wg0"
        ;;
    status)
        resolvectl status 2>/dev/null | head -20 || cat /etc/resolv.conf
        ;;
esac
